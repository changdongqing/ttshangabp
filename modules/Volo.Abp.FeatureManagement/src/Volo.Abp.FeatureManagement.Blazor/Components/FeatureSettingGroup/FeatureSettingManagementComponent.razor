@inherits Volo.Abp.AspNetCore.Components.AbpComponentBase

@if (Settings != null && Settings.HasManageHostFeaturesPermission)
{
    <MudStack>
        <MudText>@L["ManageHostFeaturesText"]</MudText>
        <MudButton Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled" OnClick="@OnManageHostFeaturesClicked">
            @L["ManageHostFeatures"]
        </MudButton>
    </MudStack>
    
    <FeatureManagementModal @ref="FeatureManagementModal"/>
}
