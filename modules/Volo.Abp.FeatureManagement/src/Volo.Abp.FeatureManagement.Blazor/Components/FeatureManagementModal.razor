@using Volo.Abp.Validation.StringValues
@using Microsoft.Extensions.Localization
@inherits AbpFeatureManagementComponentBase

<MudDialog @bind-Visible="_isVisible" MaxWidth="MaxWidth.Large" FullWidth="true">
    <TitleContent>@L["Features"]@ProviderKeyDisplayName</TitleContent>
    <DialogContent>
        @if (Groups == null || !Groups.Any())
        {
            <MudText>@L["NoFeatureFoundMessage"]</MudText>
        }
        else
        {
            <MudTabs Position="Position.Start" Rounded="true" Border="true">
                @for (var i = 0; i < Groups.Count; i++)
                {
                    var index = i;
                    <MudTabPanel Text="@Groups[index].DisplayName">
                        <MudStack Class="pa-2">
                            <MudText Typo="Typo.h6">@Groups[index].DisplayName</MudText>
                            <MudDivider Class="mb-2" />
                            @foreach (var feature in Groups[index].Features)
                            {
                                var disabled = IsDisabled(feature);
                                @if (feature.ValueType is FreeTextStringValueType)
                                {
                                    <MudTextField T="string" Label="@GetShownName(feature)" Disabled="@disabled" Value="@feature.Value" ValueChanged="@(async (v) => await OnFeatureValueChangedAsync(v, feature))" HelperText="@feature.Description" Class="mb-2" />
                                }
                                @if (feature.ValueType is SelectionStringValueType)
                                {
                                    var items = ((SelectionStringValueType)feature.ValueType).ItemSource.Items;
                                    var selectedValue = SelectionStringValues[feature.Name];
                                    <MudSelect T="string" Label="@GetShownName(feature)" Disabled="@disabled" Value="selectedValue" ValueChanged="@(s => SelectionStringValues[feature.Name] = s)" HelperText="@feature.Description" Class="mb-2">
                                        @foreach (var item in items)
                                        {
                                            <MudSelectItem Value="@item.Value">@CreateStringLocalizer(item.DisplayText.ResourceName).GetString(item.DisplayText.Name)</MudSelectItem>
                                        }
                                    </MudSelect>
                                }
                                @if (feature.ValueType is ToggleStringValueType)
                                {
                                    <MudCheckBox T="bool" Value="@ToggleValues[feature.Name]" ValueChanged="@(async (v) => await OnSelectedValueChangedAsync(v, feature))" Disabled="@disabled" Label="@GetShownName(feature)" />
                                    @if (feature.Description != null) { <MudText Typo="Typo.caption">@feature.Description</MudText> }
                                }
                            }
                        </MudStack>
                    </MudTabPanel>
                }
            </MudTabs>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseModal">@L["Cancel"]</MudButton>
        <MudButton Color="Color.Secondary" OnClick="@(async () => await DeleteAsync(ProviderName, ProviderKey))">@L["ResetToDefault"]</MudButton>
        <MudButton Color="Color.Primary" OnClick="SaveAsync">@L["Save"]</MudButton>
    </DialogActions>
</MudDialog>
