@page "/account/manage-profile"
@using Microsoft.AspNetCore.Components.Forms
@using Volo.Abp.Account.Localization
@using Volo.Abp.AspNetCore.Components.Web

@inherits AbpAccountComponentBase

<MudTabs Position="Position.Start" Rounded="true">
    @if (ChangePasswordModel != null)
    {
        <MudTabPanel Text="@L["ProfileTab:Password"]">
            <EditForm id="ChangePasswordForm" Model="@ChangePasswordModel" OnValidSubmit="ChangePasswordAsync">
                <MudTextField @bind-Value="ChangePasswordModel.CurrentPassword" Label="@L["DisplayName:CurrentPassword"]" InputType="InputType.Password" Class="mb-2" />
                <MudTextField @bind-Value="ChangePasswordModel.NewPassword" Label="@L["DisplayName:NewPassword"]" InputType="InputType.Password" Class="mb-2" />
                <MudTextField @bind-Value="ChangePasswordModel.NewPasswordConfirm" Label="@L["DisplayName:NewPasswordConfirm"]" InputType="InputType.Password" Class="mb-2" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit">@L["Save"]</MudButton>
            </EditForm>
        </MudTabPanel>
    }
    @if (PersonalInfoModel != null)
    {
        <MudTabPanel Text="@L["ProfileTab:PersonalInfo"]">
            <EditForm id="UpdatePersonalInfoForm" Model="@PersonalInfoModel" OnValidSubmit="UpdatePersonalInfoAsync">
                <MudTextField @bind-Value="PersonalInfoModel.UserName" Label="@L["DisplayName:UserName"]" Class="mb-2" />
                <MudGrid>
                    <MudItem xs="6">
                        <MudTextField @bind-Value="PersonalInfoModel.Name" Label="@L["DisplayName:Name"]" Class="mb-2" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudTextField @bind-Value="PersonalInfoModel.Surname" Label="@L["DisplayName:Surname"]" Class="mb-2" />
                    </MudItem>
                </MudGrid>
                <MudTextField @bind-Value="PersonalInfoModel.Email" Label="@L["DisplayName:Email"]" InputType="InputType.Email" Class="mb-2" />
                <MudTextField @bind-Value="PersonalInfoModel.PhoneNumber" Label="@L["DisplayName:PhoneNumber"]" Class="mb-2" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit">@L["Save"]</MudButton>
            </EditForm>
        </MudTabPanel>
    }
</MudTabs>
