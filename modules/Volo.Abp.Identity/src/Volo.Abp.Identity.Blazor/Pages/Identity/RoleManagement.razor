@page "/identity/roles"
@attribute [Authorize(IdentityPermissions.Roles.Default)]
@using Volo.Abp.Identity
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.PermissionManagement.Blazor.Components
@using Volo.Abp.Identity.Localization
@using Volo.Abp.AspNetCore.Components.Web.Theming.Layout
@using Microsoft.Extensions.Localization
@using Volo.Abp.UI.Navigation.Localization.Resource
@inject IStringLocalizer<AbpUiNavigationResource> LUiNavigation
@inherits Volo.Abp.AspNetCore.Components.AbpComponentBase

<MudText Typo="Typo.h5" Class="mb-4">@L["Roles"]</MudText>

<MudPaper Class="pa-4">
    <MudStack Row="true" Justify="Justify.FlexStart" Class="mb-4">
        @if (HasCreatePermission)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateDialogAsync">@L["NewRole"]</MudButton>
        }
    </MudStack>

    <MudDataGrid T="IdentityRoleDto" Items="@Entities" Dense="true" Hover="true" Bordered="true">
        <Columns>
            <TemplateColumn T="IdentityRoleDto" Title="@L["Actions"]" CellStyle="width:120px">
                <CellTemplate>
                    <MudMenu Label="@L["Actions"]" Variant="Variant.Outlined" Size="Size.Small" AnchorOrigin="Origin.BottomLeft">
                        @if (HasUpdatePermission)
                        {
                            <MudMenuItem OnClick="@(async () => await OpenEditDialogAsync(context.Item))">@L["Edit"]</MudMenuItem>
                        }
                        @if (HasManagePermissionsPermission)
                        {
                            <MudMenuItem OnClick="@(async () => await PermissionManagementModal.OpenAsync(PermissionProviderName, context.Item.Name))">@L["Permissions"]</MudMenuItem>
                        }
                        @if (HasDeletePermission && !context.Item.IsStatic)
                        {
                            <MudMenuItem OnClick="@(async () => await DeleteEntityAsync(context.Item))">@L["Delete"]</MudMenuItem>
                        }
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Name" Title="@L["RoleName"]" />
            <TemplateColumn T="IdentityRoleDto" Title="">
                <CellTemplate>
                    @if (context.Item.IsDefault) { <MudChip T="string" Color="Color.Primary" Size="Size.Small">@L["DisplayName:IsDefault"]</MudChip> }
                    @if (context.Item.IsPublic) { <MudChip T="string" Color="Color.Secondary" Size="Size.Small">@L["DisplayName:IsPublic"]</MudChip> }
                    @if (context.Item.IsStatic) { <MudChip T="string" Color="Color.Default" Size="Size.Small">Static</MudChip> }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>

    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4">
        <MudPagination Count="@((int)Math.Ceiling((double)TotalCount / PageSize))" Selected="@CurrentPage" SelectedChanged="PageChangedAsync" />
    </MudStack>
</MudPaper>

@* ************************* CREATE DIALOG ************************* *@
@if (HasCreatePermission && IsCreateDialogVisible)
{
    <MudDialog @bind-Visible="IsCreateDialogVisible">
        <TitleContent>@L["NewRole"]</TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="NewEntity.Name" Label="@L["DisplayName:RoleName"]" Required="true" Class="mb-2" />
            <MudCheckBox @bind-Value="NewEntity.IsDefault" Label="@L["DisplayName:IsDefault"]" />
            <MudCheckBox @bind-Value="NewEntity.IsPublic" Label="@L["DisplayName:IsPublic"]" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseCreateDialog">@L["Cancel"]</MudButton>
            <MudButton Color="Color.Primary" OnClick="CreateEntityAsync">@L["Save"]</MudButton>
        </DialogActions>
    </MudDialog>
}

@* ************************* EDIT DIALOG ************************* *@
@if (HasUpdatePermission && IsEditDialogVisible)
{
    <MudDialog @bind-Visible="IsEditDialogVisible">
        <TitleContent>@L["Edit"]</TitleContent>
        <DialogContent>
            <MudTextField @bind-Value="EditingEntity.Name" Label="@L["DisplayName:RoleName"]" Required="true" Class="mb-2" />
            <MudCheckBox @bind-Value="EditingEntity.IsDefault" Label="@L["DisplayName:IsDefault"]" />
            <MudCheckBox @bind-Value="EditingEntity.IsPublic" Label="@L["DisplayName:IsPublic"]" />
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseEditDialog">@L["Cancel"]</MudButton>
            <MudButton Color="Color.Primary" OnClick="UpdateEntityAsync">@L["Save"]</MudButton>
        </DialogActions>
    </MudDialog>
}

@if (HasManagePermissionsPermission)
{
    <PermissionManagementModal @ref="PermissionManagementModal" />
}
