@page "/identity/users"
@attribute [Authorize(IdentityPermissions.Users.Default)]
@using Microsoft.AspNetCore.Authorization
@using Volo.Abp.PermissionManagement.Blazor.Components
@using Volo.Abp.Identity.Localization
@using Volo.Abp.AspNetCore.Components.Web.Theming.Layout
@using Microsoft.Extensions.Localization
@using Volo.Abp.UI.Navigation.Localization.Resource
@using Volo.Abp.Users
@inject IStringLocalizer<AbpUiNavigationResource> LUiNavigation
@inherits Volo.Abp.AspNetCore.Components.AbpComponentBase

<MudText Typo="Typo.h5" Class="mb-4">@L["Users"]</MudText>

<MudPaper Class="pa-4">
    <MudStack Row="true" Justify="Justify.SpaceBetween" Class="mb-4">
        @if (HasCreatePermission)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateDialogAsync">@L["NewUser"]</MudButton>
        }
        <MudTextField T="string" Value="@FilterText" ValueChanged="OnSearchTextChanged" Placeholder="@L["Search"]" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="ml-auto" Style="max-width:300px;" />
    </MudStack>

    <MudDataGrid T="IdentityUserDto" Items="@Entities" Dense="true" Hover="true" Bordered="true">
        <Columns>
            <TemplateColumn T="IdentityUserDto" Title="@L["Actions"]" CellStyle="width:120px">
                <CellTemplate>
                    <MudMenu Label="@L["Actions"]" Variant="Variant.Outlined" Size="Size.Small" AnchorOrigin="Origin.BottomLeft">
                        @if (HasUpdatePermission)
                        {
                            <MudMenuItem OnClick="@(async () => await OpenEditDialogAsync(context.Item))">@L["Edit"]</MudMenuItem>
                        }
                        @if (HasManagePermissionsPermission)
                        {
                            <MudMenuItem OnClick="@(async () => await PermissionManagementModal.OpenAsync(PermissionProviderName, context.Item.Id.ToString(), context.Item.UserName))">@L["Permissions"]</MudMenuItem>
                        }
                        @if (HasDeletePermission && CurrentUser.Id != context.Item.Id)
                        {
                            <MudMenuItem OnClick="@(async () => await DeleteEntityAsync(context.Item))">@L["Delete"]</MudMenuItem>
                        }
                    </MudMenu>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.UserName" Title="@L["UserName"]" />
            <PropertyColumn Property="x => x.Email" Title="@L["EmailAddress"]" />
            <PropertyColumn Property="x => x.PhoneNumber" Title="@L["PhoneNumber"]" />
        </Columns>
    </MudDataGrid>

    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4">
        <MudPagination Count="@((int)Math.Ceiling((double)TotalCount / PageSize))" Selected="@CurrentPage" SelectedChanged="PageChangedAsync" />
    </MudStack>
</MudPaper>

@* ************************* CREATE DIALOG ************************* *@
@if (HasCreatePermission && IsCreateDialogVisible)
{
    <MudDialog @bind-Visible="IsCreateDialogVisible">
        <TitleContent>@L["NewUser"]</TitleContent>
        <DialogContent>
            <MudTabs>
                <MudTabPanel Text="@L["UserInformations"]">
                    <MudTextField @bind-Value="NewEntity.UserName" Label="@L["DisplayName:UserName"]" Required="true" Class="mb-2" />
                    <MudTextField @bind-Value="NewEntity.Name" Label="@L["DisplayName:Name"]" Class="mb-2" />
                    <MudTextField @bind-Value="NewEntity.Surname" Label="@L["DisplayName:Surname"]" Class="mb-2" />
                    <MudTextField @bind-Value="NewEntity.Password" Label="@L["DisplayName:Password"]" Required="true" InputType="@(ShowCreatePassword ? InputType.Text : InputType.Password)" Adornment="Adornment.End" AdornmentIcon="@(ShowCreatePassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)" OnAdornmentClick="@(() => ShowCreatePassword = !ShowCreatePassword)" Class="mb-2" />
                    <MudTextField @bind-Value="NewEntity.Email" Label="@L["DisplayName:Email"]" Required="true" Class="mb-2" />
                    <MudTextField @bind-Value="NewEntity.PhoneNumber" Label="@L["DisplayName:PhoneNumber"]" Class="mb-2" />
                    <MudCheckBox @bind-Value="NewEntity.IsActive" Label="@L["DisplayName:IsActive"]" />
                    <MudCheckBox @bind-Value="NewEntity.LockoutEnabled" Label="@L["DisplayName:LockoutEnabled"]" />
                </MudTabPanel>
                <MudTabPanel Text="@L["Roles"]">
                    @if (NewUserRoles != null)
                    {
                        @foreach (var role in NewUserRoles)
                        {
                            <MudCheckBox @bind-Value="@role.IsAssigned" Label="@role.Name" />
                        }
                    }
                </MudTabPanel>
            </MudTabs>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseCreateDialog">@L["Cancel"]</MudButton>
            <MudButton Color="Color.Primary" OnClick="CreateEntityAsync">@L["Save"]</MudButton>
        </DialogActions>
    </MudDialog>
}

@* ************************* EDIT DIALOG ************************* *@
@if (HasUpdatePermission && IsEditDialogVisible)
{
    <MudDialog @bind-Visible="IsEditDialogVisible">
        <TitleContent>@L["Edit"]</TitleContent>
        <DialogContent>
            <MudTabs>
                <MudTabPanel Text="@L["UserInformations"]">
                    <MudTextField @bind-Value="EditingEntity.UserName" Label="@L["DisplayName:UserName"]" Required="true" Class="mb-2" />
                    <MudTextField @bind-Value="EditingEntity.Name" Label="@L["DisplayName:Name"]" Class="mb-2" />
                    <MudTextField @bind-Value="EditingEntity.Surname" Label="@L["DisplayName:Surname"]" Class="mb-2" />
                    <MudTextField @bind-Value="EditingEntity.Password" Label="@L["DisplayName:Password"]" InputType="@(ShowEditPassword ? InputType.Text : InputType.Password)" Adornment="Adornment.End" AdornmentIcon="@(ShowEditPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)" OnAdornmentClick="@(() => ShowEditPassword = !ShowEditPassword)" Class="mb-2" />
                    <MudTextField @bind-Value="EditingEntity.Email" Label="@L["DisplayName:Email"]" Required="true" Class="mb-2" />
                    <MudTextField @bind-Value="EditingEntity.PhoneNumber" Label="@L["DisplayName:PhoneNumber"]" Class="mb-2" />
                    @if (!IsEditCurrentUser)
                    {
                        <MudCheckBox @bind-Value="EditingEntity.IsActive" Label="@L["DisplayName:IsActive"]" />
                    }
                    <MudCheckBox @bind-Value="EditingEntity.LockoutEnabled" Label="@L["DisplayName:LockoutEnabled"]" />
                </MudTabPanel>
                @if (EditUserRoles != null && EditUserRoles.Any())
                {
                    <MudTabPanel Text="@L["Roles"]">
                        @foreach (var role in EditUserRoles)
                        {
                            <MudCheckBox @bind-Value="@role.IsAssigned" Label="@role.Name" />
                        }
                    </MudTabPanel>
                }
            </MudTabs>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseEditDialog">@L["Cancel"]</MudButton>
            <MudButton Color="Color.Primary" OnClick="UpdateEntityAsync">@L["Save"]</MudButton>
        </DialogActions>
    </MudDialog>
}

@if (HasManagePermissionsPermission)
{
    <PermissionManagementModal @ref="PermissionManagementModal" />
}
