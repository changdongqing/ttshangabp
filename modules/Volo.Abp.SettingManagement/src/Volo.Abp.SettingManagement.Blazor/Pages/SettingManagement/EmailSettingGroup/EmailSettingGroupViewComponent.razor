@using Volo.Abp.SettingManagement.Localization
@inherits Volo.Abp.AspNetCore.Components.AbpComponentBase

@if (EmailSettings != null)
{
    <MudStack>
        <MudTextField @bind-Value="EmailSettings.DefaultFromDisplayName" Label="@L["DefaultFromDisplayName"]" Required="true" Class="mb-2" />
        <MudTextField @bind-Value="EmailSettings.DefaultFromAddress" Label="@L["DefaultFromAddress"]" Required="true" InputType="InputType.Email" Class="mb-2" />
        <MudTextField @bind-Value="EmailSettings.SmtpHost" Label="@L["SmtpHost"]" Class="mb-2" />
        <MudNumericField @bind-Value="EmailSettings.SmtpPort" Label="@L["SmtpPort"]" Class="mb-2" />
        <MudCheckBox @bind-Value="EmailSettings.SmtpEnableSsl" Label="@L["SmtpEnableSsl"]" />
        <MudCheckBox @bind-Value="EmailSettings.SmtpUseDefaultCredentials" Label="@L["SmtpUseDefaultCredentials"]" />
        @if (!EmailSettings.SmtpUseDefaultCredentials)
        {
            <MudTextField @bind-Value="EmailSettings.SmtpDomain" Label="@L["SmtpDomain"]" Class="mb-2" />
            <MudTextField @bind-Value="EmailSettings.SmtpUserName" Label="@L["SmtpUserName"]" Class="mb-2" />
            <MudTextField @bind-Value="EmailSettings.SmtpPassword" Label="@L["SmtpPassword"]" InputType="InputType.Password" Placeholder="@L["SmtpPasswordPlaceholder"].Value" Class="mb-2" />
        }
        <MudStack Row="true" Class="mt-2">
            @if (HasSendTestEmailPermission)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="OpenSendTestEmailModalAsync">@L["SendTestEmail"]</MudButton>
            }
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="UpdateSettingsAsync">@L["Save"]</MudButton>
        </MudStack>
    </MudStack>

    @if (HasSendTestEmailPermission && _isTestEmailDialogVisible)
    {
        <MudDialog @bind-Visible="_isTestEmailDialogVisible">
            <TitleContent>@L["SendTestEmail"]</TitleContent>
            <DialogContent>
                <MudTextField @bind-Value="SendTestEmailInput.SenderEmailAddress" Label="@L["SenderEmailAddress"]" Required="true" Class="mb-2" />
                <MudTextField @bind-Value="SendTestEmailInput.TargetEmailAddress" Label="@L["TargetEmailAddress"]" Required="true" Class="mb-2" />
                <MudTextField @bind-Value="SendTestEmailInput.Subject" Label="@L["Subject"]" Required="true" Class="mb-2" />
                <MudTextField @bind-Value="SendTestEmailInput.Body" Label="@L["Body"]" Class="mb-2" />
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="CloseSendTestEmailModalAsync">@L["Cancel"]</MudButton>
                <MudButton Color="Color.Primary" OnClick="SendTestEmailAsync">@L["Send"]</MudButton>
            </DialogActions>
        </MudDialog>
    }
}
