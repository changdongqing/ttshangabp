@using Volo.Abp.SettingManagement.Localization
@inherits Volo.Abp.AspNetCore.Components.AbpComponentBase

@if (TimezoneSettings != null)
{
    <MudStack>
        <MudSelect T="string" Label="@L["DisplayName:Timezone"]" Value="TimezoneSettings.Timezone" ValueChanged="OnSelectedValueChangedAsync" HelperText="@L["TimezoneHelpText"].Value">
            @foreach (var item in TimezoneSettings.TimeZoneItems)
            {
                <MudSelectItem Value="@item.Value">@item.Name</MudSelectItem>
            }
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="UpdateSettingsAsync">@L["Save"]</MudButton>
    </MudStack>
}
